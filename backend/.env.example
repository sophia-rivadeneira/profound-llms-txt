# Copy this file to .env and edit the values for your local environment.
# The .env file is gitignored.

# Postgres connection string. Format: postgresql+asyncpg://<user>@<host>:<port>/<db>
# For a local Homebrew Postgres install, the user is your macOS username and there's no password.
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/profound

# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000

# Environment name — used for the /health endpoint and logging context.
ENV=development
